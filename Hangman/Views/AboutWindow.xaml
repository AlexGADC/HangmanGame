<Window x:Class="Hangman.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About the Developer" Height="300" Width="300"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid Margin="20">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="HANGMAN GAME" 
                       FontSize="24" FontWeight="Bold" Foreground="#2C3E50" 
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <Separator Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Author: " FontWeight="Bold" Width="100"/>
                <TextBlock Text="{Binding AuthorName}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Group: " FontWeight="Bold" Width="100"/>
                <TextBlock Text="{Binding GroupName}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Specialization: " FontWeight="Bold" Width="100"/>
                <TextBlock Text="{Binding Specialization}"/>
            </StackPanel>

            <Button Content="Close" 
                    IsCancel="True"
                    Width="100" Height="30" 
                    Margin="0,30,0,0"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>