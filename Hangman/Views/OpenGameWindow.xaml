<Window x:Class="Hangman.Views.OpenGameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Height="400" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Your Saved Games:" 
                   FontSize="18" 
                   FontWeight="Bold" 
                   Margin="0,0,0,10"/>

        <ListBox Grid.Row="1" 
                 ItemsSource="{Binding UserSaves}" 
                 SelectedItem="{Binding SelectedSave}"
                 Margin="0,0,0,10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="5">
                        <TextBlock Text="{Binding SaveDate, StringFormat='Date: {0:MM/dd/yyyy HH:mm}'}" 
                                   FontWeight="Bold" FontSize="14"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Category: " FontStyle="Italic"/>
                            <TextBlock Text="{Binding Category}" Margin="5,0,20,0"/>
                            <TextBlock Text="Level: " FontStyle="Italic"/>
                            <TextBlock Text="{Binding Level}"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Load Game" 
                    Command="{Binding SelectCommand}" 
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Width="100" Height="30" Margin="0,0,10,0"
                    Background="LightGreen"/>

            <Button Content="Cancel" 
                    IsCancel="True"
                    Width="100" Height="30"/>
        </StackPanel>
    </Grid>
</Window>