<Window x:Class="Hangman.Views.PlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hangman.Views"
        xmlns:converters="clr-namespace:Hangman.Converters"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        mc:Ignorable="d"
        Title="PlayWindow" 
        Height="560" 
        Width="1000"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="KeyDown">
            <i:InvokeCommandAction Command="{Binding HandleKeyDownCommand}" 
                                   PassEventArgsToCommand="True"/>
        </i:EventTrigger>
   
        <i:EventTrigger EventName="Closed">
            <i:InvokeCommandAction Command="{Binding CleanupCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Window.Resources>
        <converters:LowTimeConverter x:Key="LowTimeConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Menu>
                <MenuItem Header="File">
                    <MenuItem Header="New Game" Command="{Binding NewGameCommand}"/>
                    <MenuItem Header="Open Game" Command="{Binding OpenGameCommand}"/>
                    <MenuItem Header="Save Game" Command="{Binding SaveGameCommand}"/>
                    <MenuItem Header="Statistics" Command="{Binding StatisticsCommand}"/>
                    <MenuItem Header="Cancel" Command="{Binding CancelCommand}"
                              CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
                </MenuItem>
                <MenuItem Header="Cateogry">
                    <MenuItem.Style>
                        <Style TargetType="MenuItem">
                            <Setter Property="IsEnabled" Value="True"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGameStarted}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </MenuItem.Style>
                    <MenuItem Header="All Categories" IsCheckable="True" Command="{Binding SelectCategoryCommand}" CommandParameter="{Binding Header, RelativeSource={RelativeSource Self}}"/>
                    <MenuItem Header="Cars" IsCheckable="True" Command="{Binding SelectCategoryCommand}" CommandParameter="{Binding Header, RelativeSource={RelativeSource Self}}"/>
                    <MenuItem Header="Movies" IsCheckable="True" Command="{Binding SelectCategoryCommand}" CommandParameter="{Binding Header, RelativeSource={RelativeSource Self}}"/>
                    <MenuItem Header="Flowers" IsCheckable="True" Command="{Binding SelectCategoryCommand}" CommandParameter="{Binding Header, RelativeSource={RelativeSource Self}}"/>
                    <MenuItem Header="Sports" IsCheckable="True" Command="{Binding SelectCategoryCommand}" CommandParameter="{Binding Header, RelativeSource={RelativeSource Self}}"/>
                </MenuItem>
                <MenuItem Header="Help">
                    <MenuItem Header="About" Command="{Binding AboutCommand}"/>
                </MenuItem>
            </Menu>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">

                <Grid Grid.Column="0">
                    <Grid x:Name="WaitingArea">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsGameStarted}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Please start a game!" 
                                       HorizontalAlignment="Center" 
                                       FontSize="20" 
                                       FontFamily="Arial Rounded MT Bold"/>
                            <Image gif:ImageBehavior.AnimatedSource="/Assets/LoadingScreen/StartingGame.gif" 
                                   Width="200" Height="200" Margin="10"/>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="ActiveGameArea">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsGameStarted}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <StackPanel Margin="30,20,30,0">
                            <TextBlock Text="{Binding CurrentLevel, StringFormat='Level {0}'}" 
                                       FontSize="22" FontFamily="Arial Rounded MT Bold" Margin="0,0,0,15"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,30,0">
                                <TextBlock Text="Time: " FontSize="20" FontFamily="Arial Rounded MT Bold"/>
                                <TextBlock Text="{Binding RemainingTime, StringFormat='{}{0}'}" 
                                           FontSize="22" 
                                           FontFamily="Arial Rounded MT Bold"
                                           Width="50">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="Black"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RemainingTime, Converter={StaticResource LowTimeConverter}}" Value="True">
                                                    <Setter Property="Foreground" Value="Red"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Image Grid.Column="0" 
                                       Source="{Binding CurrentImage}"
                                       Width="280" Height="280" 
                                       HorizontalAlignment="Left" 
                                       VerticalAlignment="Top"/>

                                <StackPanel Grid.Column="1" Margin="30,0,0,0" VerticalAlignment="Top">
                                    <TextBlock Text="Mistakes:" FontSize="16" FontWeight="Bold" Foreground="DimGray" Margin="0,0,0,5"/>
                                    <ItemsControl ItemsSource="{Binding LivesProgress}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="DarkRed" BorderThickness="2" CornerRadius="3" Margin="3" Width="35" Height="40" Background="#FFF0F0F0">
                                                    <TextBlock Text="{Binding}" Foreground="Red" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Arial Black"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="Guess a letter:" FontSize="16" FontWeight="Bold" Foreground="DimGray" Margin="0,25,0,5"/>

                                    <ItemsControl ItemsSource="{Binding Alphabet}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Width="415" HorizontalAlignment="Left"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding Letter}" FontSize="18" Width="42" Height="42" Margin="2"
                                                        Command="{Binding DataContext.GuessLetterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding IsEnabled}">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsEnabled" Value="False">
                                                                    <Setter Property="Background" Value="LightGray"/>
                                                                    <Setter Property="Foreground" Value="Gray"/>
                                                                    <Setter Property="Opacity" Value="0.5"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="{Binding CurrentCategory, StringFormat='Selected category is: {0}'}" 
                                       FontSize="20" Margin="0,25,0,0" FontFamily="Arial Rounded MT Bold" Foreground="#333"/>

                            <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                                <TextBlock Text="Word: " 
                                           FontSize="30" 
                                           FontFamily="Arial Rounded MT Bold" 
                                           VerticalAlignment="Center"/>

                                <ItemsControl ItemsSource="{Binding HiddenWordLetters}" 
                                              VerticalAlignment="Center"
                                              Margin="10,0,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="Black" BorderThickness="0,0,0,2" Margin="5" Width="35">
                                                <TextBlock Text="{Binding}" 
                                                           FontSize="32" 
                                                           HorizontalAlignment="Center" 
                                                           FontFamily="Consolas" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>

            <StackPanel Grid.Column="1" 
                        VerticalAlignment="Top" 
                        HorizontalAlignment="Right" 
                        Margin="10"
                        DataContext="{Binding CurrentUser}">
                <TextBlock Text="{Binding UserName}" FontSize="16" HorizontalAlignment="Center"/>
                <Image Source="{Binding ImagePath}" 
                       Width="150" 
                       Height="150" 
                       Margin="10"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
