<Window x:Class="Hangman.Views.StartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hangman"
        mc:Ignorable="d"
        Title="StartWindow" 
        Height="450" 
        Width="600"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row = "0" Text="Welcome to Hangman!" HorizontalAlignment="Center" FontSize="24" Margin="10"/>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Select a user from the list below:" Margin="0,0,0,5"/>
                <ListBox ItemsSource="{Binding Users}" 
                         SelectedItem="{Binding SelectedUser}" 
                         DisplayMemberPath="UserName"
                         Height="250" 
                         Width="230" 
                         HorizontalAlignment="Left"/>
            </StackPanel>

            <StackPanel Grid.Column="1" HorizontalAlignment="Center" DataContext="{Binding SelectedUser}">
                <Image Source="{Binding ImagePath}" 
                       Width="150" 
                       Height="150" 
                       Margin="10"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="«"
                            Command="{Binding DataContext.PreviousImageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Width="40" Margin="5"/>
                    <Button Content="»"
                            Command="{Binding DataContext.NextImageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Width="40" Margin="5"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="45,5,0,15" RenderTransformOrigin="0.742,-0.557">
            <Button Content="New User" Command="{Binding NewUserCommand}" Width="80" Margin="5"/>
            <Button Content="Delete User" Command="{Binding DeleteUserCommand}" Width="80" Margin="5"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,69,15" RenderTransformOrigin="0.268,0.504">
            <Button Content="Play" Command="{Binding PlayCommand}" Width="80" Margin="5"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}" Width="80" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
