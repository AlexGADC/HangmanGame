<Window x:Class="Hangman.Views.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Hangman.Views"
        mc:Ignorable="d"
        Title="StatisticsWindow" Height="300" Width="450">
    
        <Grid Margin="15">
              <Grid.RowDefinitions>
                     <RowDefinition Height="Auto"/>
                     <RowDefinition Height="*"/>
                     <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>

              <StackPanel Grid.Row="0" Margin="0,0,0,10">
                     <TextBlock Text="Overall Progress" FontSize="20" FontWeight="Bold"/>
                  
                     <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                             <TextBlock Text="Total Games Played: " FontSize="14"/>
                             <TextBlock Text="{Binding TotalGames}" FontWeight="Bold" FontSize="14" Margin="5,0,0,0"/>
                     </StackPanel>

                     <Separator Margin="0,10,0,0"/>

                     <TextBlock Text="Wins per Category:" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,5"/>
              </StackPanel>

              <ListBox Grid.Row="1" ItemsSource="{Binding Stats}" BorderThickness="0" Background="Transparent">
                     <ListBox.ItemTemplate>
                         <DataTemplate>
                             <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
                                  <Grid>
                                        <Grid.ColumnDefinitions>
                                             <ColumnDefinition Width="*"/>
                                             <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                      
                                        <TextBlock Text="{Binding CategoryName}" FontSize="14" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                 <TextBlock Text="{Binding Wins}" 
                                                            FontWeight="Bold" 
                                                            Foreground="DarkGreen" 
                                                            FontSize="14"/>
                                                 <TextBlock Text=" wins" 
                                                            FontSize="12" 
                                                            VerticalAlignment="Bottom" 
                                                            Margin="2,0,0,0"/>
                                        </StackPanel>
                                  </Grid>
                             </Border>
                         </DataTemplate>
                     </ListBox.ItemTemplate>
              </ListBox>

              <Button Grid.Row="2" Content="Close" IsCancel="True" 
                Width="100" Height="30" Margin="0,15,0,0"/>
        </Grid>
</Window>
